{
  "name": "@coval/wizard",
  "version": "0.1.0",
  "description": "Add Coval OTel tracing to your AI agent with one command",
  "type": "module",
  "bin": {
    "coval-wizard": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coval-ai/wizard"
  },
  "keywords": [
    "coval",
    "opentelemetry",
    "tracing",
    "ai-agent",
    "wizard"
  ],
  "license": "MIT"
}
